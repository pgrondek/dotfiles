#!/usr/bin/env bash

function arch_update() {
  if [ -f /usr/bin/pacman ]; then
    echo -e "\e[32m[pacman]\e[0m updating"
    sudo pacman -Suy
  else
    echo -e "\e[31m[pacman]\e[0m missing, skipping"
  fi

  if [ -f /usr/bin/paccache ]; then
    echo -e "\e[32m[paccache]\e[0m cleaning pacman cache"
    paccache -r
  else
    echo -e "\e[31m[paccache]\e[0m missing, not cleaning pacman cache"
  fi
}

function debian_update() {
  if [ -f /usr/bin/apt ]; then
    declare APT
    declare APT_NAME
    if [ -f /usr/bin/aptitude ]; then
      APT=/usr/bin/aptitude
      APT_NAME=aptitude
    elif [ -f /usr/bin/apt-get ]; then
      APT=/usr/bin/apt-get
      APT_NAME=apt-get
    else
      APT=/usr/bin/apt
      APT_NAME=apt
    fi
    echo -e "\e[32m[${APT_NAME}]\e[0m Updating"
    ${APT} update
    ${APT} upgrade
  else
    echo -e "\e[31m[apt]\e[0m missing, skipping"
  fi
}

function flatpak_update() {
  if [ -f /usr/bin/flatpak ]; then
    echo -e "\e[32m[flatpak]\e[0m updating"
    flatpak update
    flatpak uninstall --unused
  else
    echo -e "\e[31m[flatpak]\e[0m missing, skipping"
  fi
}

arch_update
debian_update
flatpak_update
