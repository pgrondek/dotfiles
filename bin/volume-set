#!/usr/bin/env bash

URGENCY=low
EXPIRE=5000

ACTION="$1"

if [[ "$ACTION" == "-i" ]]; then
  pamixer -i "$2"
elif [[ "$ACTION" == "-d" ]]; then
  pamixer -d "$2"
fi

LEVEL=$(pamixer --get-volume)
NOTIFY_CMD="notify-send -u $URGENCY -t $EXPIRE VOLUME "

notify-send -u $URGENCY \
  -h "int:value:$LEVEL" \
  -h string:x-dunst-stack-tag:volume_notif \
  -t $EXPIRE \
  "VOLUME: $LEVEL"
